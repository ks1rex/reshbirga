# ── Supabase ──────────────────────────────────────────────────────────────────
# Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here          # нужен только smoke-тесту
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # SECRET — не публиковать

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
# URL frontend для CORS (без слэша)
# Локально:  http://localhost:5173
# Прод:      https://<gh-username>.github.io
FRONTEND_URL=http://localhost:5173

# ── Бизнес-логика ─────────────────────────────────────────────────────────────
# Через сколько часов заказ автоподтверждается (awaiting_confirmation → completed)
AUTO_CONFIRM_HOURS=24

# ── AI-модерация (опционально) ────────────────────────────────────────────────
# DeepSeek API key; если отсутствует — AI-проверка не запускается
DEEPSEEK_API_KEY=your_deepseek_api_key_here   # SECRET

# ── Smoke test ────────────────────────────────────────────────────────────────
# Учётные данные существующего admin-аккаунта
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password
BACKEND_URL=http://localhost:3001
